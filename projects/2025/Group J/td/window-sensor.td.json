{
  "@context": [
    "https://www.w3.org/2022/wot/td/v1.1",
    {
      "@language": "it"
    }
  ],
  "@type": "Thing",
  "id": "urn:wot:window-sensor:{uuid}",
  "title": "Window Sensor",
  "description": "Sensore che rileva apertura e chiusura delle finestre",
  "securityDefinitions": {
    "nosec_sc": {
      "scheme": "nosec"
    }
  },
  "security": "nosec_sc",
  "base": "http://localhost:3000/things/window-sensor/",
  "properties": {
    "isOpen": {
      "title": "Stato Finestra",
      "description": "Indica se la finestra è aperta",
      "type": "boolean",
      "readOnly": true,
      "forms": [
        {
          "href": "/things/window-sensor/properties/isOpen",
          "contentType": "application/json",
          "op": "readproperty"
        }
      ]
    },
    "lastUpdate": {
      "title": "Ultimo Aggiornamento",
      "description": "Timestamp dell'ultimo evento",
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "forms": [
        {
          "href": "/things/window-sensor/properties/lastUpdate",
          "contentType": "application/json",
          "op": "readproperty"
        }
      ]
    }
  },
  "events": {
    "windowOpened": {
      "title": "Finestra Aperta/Chiusa",
      "description": "Evento generato quando la finestra viene aperta o chiusa",
      "data": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "isOpen": {
            "type": "boolean"
          }
        },
        "required": ["timestamp", "isOpen"]
      },
      "forms": [
        {
          "href": "mqtt://localhost:1883/events/window-sensor/windowOpened",
          "contentType": "application/json",
          "op": "subscribeevent"
        }
      ]
    }
  }
}