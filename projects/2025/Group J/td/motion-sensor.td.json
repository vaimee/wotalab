{
  "@context": [
    "https://www.w3.org/2022/wot/td/v1.1",
    {
      "@language": "it"
    }
  ],
  "@type": "Thing",
  "id": "urn:wot:motion-sensor:{uuid}",
  "title": "Motion Sensor",
  "description": "Sensore che rileva movimento all'interno dell'ambiente",
  "securityDefinitions": {
    "nosec_sc": {
      "scheme": "nosec"
    }
  },
  "security": "nosec_sc",
  "base": "http://localhost:3000/things/motion-sensor/",
  "properties": {
    "motionDetected": {
      "title": "Movimento Rilevato",
      "description": "Indica se è stato rilevato movimento",
      "type": "boolean",
      "readOnly": true,
      "forms": [
        {
          "href": "/things/motion-sensor/properties/motionDetected",
          "contentType": "application/json",
          "op": "readproperty"
        }
      ]
    },
    "lastUpdate": {
      "title": "Ultimo Aggiornamento",
      "description": "Timestamp dell'ultimo evento",
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "forms": [
        {
          "href": "/things/motion-sensor/properties/lastUpdate",
          "contentType": "application/json",
          "op": "readproperty"
        }
      ]
    }
  },
  "events": {
    "motionOccurred": {
      "title": "Movimento Rilevato",
      "description": "Evento generato quando viene rilevato (o cessa) movimento",
      "data": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "motionDetected": {
            "type": "boolean"
          }
        },
        "required": ["timestamp", "motionDetected"]
      },
      "forms": [
        {
          "href": "mqtt://localhost:1883/events/motion-sensor/motionDetected",
          "contentType": "application/json",
          "op": "subscribeevent"
        }
      ]
    }
  }
}