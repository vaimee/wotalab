{
  "@context": {
    "@version": 1.1,
    "wot": "https://www.w3.org/2019/wot/td#",
    "td": "https://www.w3.org/2019/wot/td#",
    "hctl": "https://www.w3.org/2019/wot/hypermedia#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "proj": "urn:wot:home-security-ontology#",

    "subClassOf": { "@id": "rdfs:subClassOf", "@type": "@id" },
    "domain": { "@id": "rdfs:domain", "@type": "@id" },
    "range": { "@id": "rdfs:range", "@type": "@id" },
    "comment": "rdfs:comment",
    "label": "rdfs:label"
  },

  "@graph": [

    {
      "@id": "proj:Thing",
      "@type": "owl:Class",
      "subClassOf": "td:Thing",
      "label": "Thing",
      "comment": "Classe radice. Ogni dispositivo o servizio del sistema e' esposto come WoT Thing con una propria Thing Description (id, title, type, description, securityDefinitions). L'id e' generato a runtime tramite uuidv4()."
    },
    {
      "@id": "proj:Sensor",
      "@type": "owl:Class",
      "subClassOf": "proj:Thing",
      "label": "Sensor",
      "comment": "Thing che osserva lo stato dell'ambiente. Espone solo Property in lettura (readOnly) ed Event generati al cambio di stato. Non espone Action. Istanze: DoorSensor, WindowSensor, MotionSensor."
    },
    {
      "@id": "proj:Actuator",
      "@type": "owl:Class",
      "subClassOf": "proj:Thing",
      "label": "Actuator",
      "comment": "Thing che mantiene uno stato osservabile (Property readOnly) ma il cui stato viene modificato tramite Action invocate da un Consumer, non da letture esterne. Genera Event quando lo stato cambia. Istanza: AlarmSystem."
    },
    {
      "@id": "proj:Service",
      "@type": "owl:Class",
      "subClassOf": "proj:Thing",
      "label": "Service",
      "comment": "Thing senza stato persistente esposto come Property: espone solo Action invocabili e genera Event a fronte dell'esecuzione. Istanza: NotificationService."
    },
    {
      "@id": "proj:Consumer",
      "@type": "owl:Class",
      "label": "Consumer",
      "comment": "Ruolo che consuma le interaction affordance delle Thing (legge Property, invoca Action, si sottoscrive a Event) senza essere a sua volta esposto come Thing con una propria Thing Description. Istanza: Orchestrator."
    },

    {
      "@id": "proj:InteractionAffordance",
      "@type": "owl:Class",
      "subClassOf": "td:InteractionAffordance",
      "label": "InteractionAffordance",
      "comment": "Classe astratta per le tre forme di interazione WoT esposte da una Thing tramite la sua Thing Description."
    },
    {
      "@id": "proj:Property",
      "@type": "owl:Class",
      "subClassOf": ["proj:InteractionAffordance", "td:PropertyAffordance"],
      "label": "Property",
      "comment": "Espone lo stato corrente di una Thing. Nel progetto tutte le Property sono readOnly: il loro valore cambia solo internamente alla Thing, non via scrittura esterna."
    },
    {
      "@id": "proj:Action",
      "@type": "owl:Class",
      "subClassOf": ["proj:InteractionAffordance", "td:ActionAffordance"],
      "label": "Action",
      "comment": "Operazione invocabile su una Thing che ne modifica lo stato o produce un effetto (es. invio notifica)."
    },
    {
      "@id": "proj:Event",
      "@type": "owl:Class",
      "subClassOf": ["proj:InteractionAffordance", "td:EventAffordance"],
      "label": "Event",
      "comment": "Notifica asincrona generata da una Thing al verificarsi di una condizione, distribuita in modalita' publish/subscribe tramite long-polling HTTP (operazione subscribeevent del binding WoT)."
    },

    {
      "@id": "proj:ProtocolBinding",
      "@type": "owl:Class",
      "label": "ProtocolBinding",
      "comment": "Meccanismo di trasporto con cui una InteractionAffordance e' raggiungibile, descritto nel campo forms della Thing Description."
    },
    {
      "@id": "proj:HTTPBinding",
      "@type": "owl:Class",
      "subClassOf": "proj:ProtocolBinding",
      "label": "HTTPBinding",
      "comment": "Unico protocol binding usato dal sistema: operazioni sincrone request/response (readproperty sulle Property, invokeaction sulle Action) e sottoscrizione asincrona agli Event tramite long-polling (subscribeevent)."
    },

    {
      "@id": "proj:exposesProperty",
      "@type": "owl:ObjectProperty",
      "domain": "proj:Thing",
      "range": "proj:Property",
      "comment": "Collega una Thing a una Property che espone."
    },
    {
      "@id": "proj:exposesAction",
      "@type": "owl:ObjectProperty",
      "domain": "proj:Thing",
      "range": "proj:Action",
      "comment": "Collega una Thing a una Action che espone."
    },
    {
      "@id": "proj:exposesEvent",
      "@type": "owl:ObjectProperty",
      "domain": "proj:Thing",
      "range": "proj:Event",
      "comment": "Collega una Thing a un Event che puo' generare."
    },
    {
      "@id": "proj:usesBinding",
      "@type": "owl:ObjectProperty",
      "domain": "proj:InteractionAffordance",
      "range": "proj:ProtocolBinding",
      "comment": "Collega una InteractionAffordance al protocol binding tramite cui e' raggiungibile (forms.href)."
    },
    {
      "@id": "proj:subscribesToEvent",
      "@type": "owl:ObjectProperty",
      "domain": "proj:Consumer",
      "range": "proj:Event",
      "comment": "Il Consumer si sottoscrive a un Event di una Thing consumata (WoT subscribeEvent, via long-polling HTTP) - vedi Orchestrator._subscribeToEvents()."
    },
    {
      "@id": "proj:invokesAction",
      "@type": "owl:ObjectProperty",
      "domain": "proj:Consumer",
      "range": "proj:Action",
      "comment": "Il Consumer invoca una Action su una Thing consumata (WoT invokeAction) - vedi Orchestrator.triggerSecurityAlert(), che chiama invokeAction('triggerAlarm') su AlarmSystem e invokeAction('sendNotification') su NotificationService."
    },
    {
      "@id": "proj:triggers",
      "@type": "owl:ObjectProperty",
      "domain": "proj:Event",
      "range": "proj:Action",
      "comment": "Relazione di causalita' applicativa mediata dall'Orchestrator: un Event in arrivo, se securityMode e' attivo, fa scattare in parallelo triggerAlarm (su AlarmSystem) e sendNotification (su NotificationService). Esempi: doorOpened -> triggerAlarm + sendNotification, windowOpened -> triggerAlarm + sendNotification, motionDetected -> triggerAlarm + sendNotification."
    },

    {
      "@id": "proj:DoorSensor",
      "@type": "owl:Class",
      "subClassOf": "proj:Sensor",
      "label": "DoorSensor",
      "comment": "Property: isOpen (boolean, readOnly), lastUpdate (string ISO 8601, readOnly). Event: doorOpened (payload: timestamp, isOpen). Nessuna Action."
    },
    {
      "@id": "proj:WindowSensor",
      "@type": "owl:Class",
      "subClassOf": "proj:Sensor",
      "label": "WindowSensor",
      "comment": "Property: isOpen (boolean, readOnly), lastUpdate (string ISO 8601, readOnly). Event: windowOpened (payload: timestamp, isOpen). Nessuna Action."
    },
    {
      "@id": "proj:MotionSensor",
      "@type": "owl:Class",
      "subClassOf": "proj:Sensor",
      "label": "MotionSensor",
      "comment": "Property: motionDetected (boolean, readOnly), lastUpdate (string ISO 8601, readOnly). Event: motionDetected (payload: timestamp, motionDetected). Nessuna Action."
    },
    {
      "@id": "proj:AlarmSystem",
      "@type": "owl:Class",
      "subClassOf": "proj:Actuator",
      "label": "AlarmSystem",
      "comment": "Property: alarmStatus (string enum RESET/TRIGGERED, readOnly). Action: triggerAlarm (porta alarmStatus a TRIGGERED), resetAlarm (porta alarmStatus a RESET). Event: alarmTriggered (payload: timestamp, alarmStatus=TRIGGERED), emesso solo da triggerAlarm."
    },
    {
      "@id": "proj:NotificationService",
      "@type": "owl:Class",
      "subClassOf": "proj:Service",
      "label": "NotificationService",
      "comment": "Nessuna Property esposta in TD (lo stato notifications e' interno). Action: sendNotification(message, severity; default severity: info) con output: id (uuid), timestamp, message, severity. Event: notificationSent (payload: id, timestamp, message, severity)."
    },
    {
      "@id": "proj:Orchestrator",
      "@type": "owl:Class",
      "subClassOf": "proj:Consumer",
      "label": "Orchestrator",
      "comment": "Non e' una WoT Thing (nessuna Thing Description propria). Scopre le Thing tramite la Thing Directory e le consuma con WoT.consume(). Mantiene lo stato applicativo securityMode (boolean) e alertHistory (array). Si sottoscrive (subscribeEvent) a: doorOpened, windowOpened, motionDetected. Se securityMode e' attivo, un evento di apertura o movimento fa scattare in parallelo invokeAction('triggerAlarm') su AlarmSystem e invokeAction('sendNotification') su NotificationService. Espone inoltre activateSecurityMode() e deactivateSecurityMode(): la prima invoca sendNotification, la seconda invoca resetAlarm e poi sendNotification."
    }
  ]
}
