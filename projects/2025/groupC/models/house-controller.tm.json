{
    "@context": [
        "https://www.w3.org/2019/wot/td/v1"
    ],
    "title": "houseController",
    "securityDefinitions": {
        "nosec_sc": {
            "scheme": "nosec"
        }
    },
    "security": [
        "nosec_sc"
    ],
    "description": "Global state for the smart home including operation modes and security status",
    "properties": {
        "currentMode": {
            "type": "string",
            "enum": [
                "HOME",
                "NIGHT",
                "ECO",
                "VACATION"
            ],
            "description": "Operation mode of the house",
            "readOnly": false
        },
        "alarmActive": {
            "type": "boolean",
            "description": "Indicates if the security alarm is currently triggered",
            "readOnly": true
        },
        "alarmReason": {
            "type": "string",
            "description": "Reason why the alarm was triggered",
            "readOnly": true
        },
        "simulationEnabled": {
            "type": "boolean",
            "description": "If true, sensors will generate random data. If false, they will stay on their current values.",
            "readOnly": false
        }
    },
    "actions": {
        "setMode": {
            "description": "Change the house operation mode",
            "input": {
                "type": "string",
                "enum": [
                    "HOME",
                    "NIGHT",
                    "ECO",
                    "VACATION"
                ]
            }
        },
        "resetAlarm": {
            "description": "Dismiss the current alarm status"
        }
    },
    "events": {
        "alarmTriggered": {
            "description": "Emitted when a security breach is detected",
            "data": {
                "type": "object",
                "properties": {
                    "reason": {
                        "type": "string"
                    },
                    "timestamp": {
                        "type": "string"
                    }
                }
            }
        }
    }
}