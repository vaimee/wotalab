{
    "@context": [
        "https://www.w3.org/2019/wot/td/v1",
        {
            "saref": "https://saref.etsi.org/core/",
            "sosa": "http://www.w3.org/ns/sosa/"
        }
    ],
    "@type": [
        "sosa:Sensor"
    ],
    "title": "windowSensor",
    "description": "Window open/closed sensor for a smart room",
    "securityDefinitions": {
        "nosec_sc": {
            "scheme": "nosec"
        }
    },
    "security": [
        "nosec_sc"
    ],
    "properties": {
        "isOpen": {
            "@type": "saref:OpenCloseState",
            "type": "boolean",
            "title": "Window Open",
            "description": "True if the window is open, false if it is closed",
            "readOnly": false,
            "observable": true
        },
        "status": {
            "type": "string",
            "title": "Status",
            "description": "Sensor runtime status",
            "enum": [
                "online",
                "offline",
                "error"
            ],
            "readOnly": false,
            "observable": true
        }
    },
    "actions": {
        "reset": {
            "description": "Reset internal sensor state (e.g., clear last error)"
        }
    },
    "events": {
        "windowStateChanged": {
            "description": "Emitted when the window state changes (open/closed)",
            "data": {
                "type": "boolean"
            }
        },
        "sensorError": {
            "description": "Emitted when the sensor adapter detects an error",
            "data": {
                "type": "string"
            }
        }
    }
}