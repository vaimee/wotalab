{
    "@context": [
        "https://www.w3.org/2019/wot/td/v1",
        {
            "saref": "https://saref.etsi.org/core/",
            "sosa": "http://www.w3.org/ns/sosa/",
            "smart": "http://example.org/smart-room#"
        }
    ],
    "@type": [
        "saref:Heater",
        "sosa:Actuator",
        "smart:Boiler"
    ],
    "title": "boilerActuator",
    "description": "Boiler actuator for heating control",
    "securityDefinitions": {
        "nosec_sc": {
            "scheme": "nosec"
        }
    },
    "security": [
        "nosec_sc"
    ],
    "properties": {
        "isOn": {
            "@type": "saref:OnOffState",
            "type": "boolean",
            "title": "Boiler State",
            "description": "True if the boiler is heating",
            "readOnly": false,
            "observable": true
        },
        "mode": {
            "type": "string",
            "title": "Control Mode",
            "description": "Manual mode ignores automation; auto mode allows the reasoner to control the boiler",
            "enum": [
                "manual",
                "auto"
            ],
            "readOnly": false,
            "observable": true
        },
        "status": {
            "type": "string",
            "title": "Status",
            "description": "Actuator runtime status",
            "enum": [
                "online",
                "offline",
                "error"
            ],
            "readOnly": true,
            "observable": true
        }
    },
    "actions": {
        "turnOn": {
            "@type": "saref:OnCommand",
            "description": "Turn boiler ON"
        },
        "turnOff": {
            "@type": "saref:OffCommand",
            "description": "Turn boiler OFF"
        },
        "toggle": {
            "@type": "saref:ToggleCommand",
            "description": "Toggle boiler state"
        },
        "reset": {
            "description": "Reset internal actuator state"
        }
    },
    "events": {
        "stateChanged": {
            "description": "Emitted when boiler state changes",
            "data": {
                "type": "boolean"
            }
        }
    }
}