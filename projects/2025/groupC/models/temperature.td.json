{
    "@context": [
        "https://www.w3.org/2022/wot/td/v1.1",
        {
            "saref": "https://saref.etsi.org/core/",
            "unit": "http://qudt.org/vocab/unit/",
            "smart": "http://example.org/smart-room#"
        }
    ],
    "@type": ["smart:TempHumiditySensor", "saref:TemperatureSensor", "saref:HumiditySensor"],
    "title": "tempHumiditySensor",
    "description": "Exposed HTTP Thing. Serves cached temperature and humidity data from the MQTT device.",
    "securityDefinitions": {
        "nosec_sc": { "scheme": "nosec" }
    },
    "security": ["nosec_sc"],
    "properties": {
        "temperature": {
            "@type": "saref:Temperature",
            "type": "number",
            "title": "Temperature",
            "description": "Cached air temperature in Celsius (sourced from MQTT device)",
            "unit": "unit:Deg_C",
            "minimum": -10,
            "maximum": 50,
            "readOnly": true,
            "observable": true,
            "forms": [
                {
                    "href": "http://localhost:8080/temphumiditysensor/properties/temperature",
                    "contentType": "application/json",
                    "op": ["readproperty", "observeproperty"]
                }
            ]
        },
        "humidityPct": {
            "@type": "saref:Humidity",
            "type": "number",
            "title": "Relative Humidity",
            "description": "Cached relative humidity percentage (sourced from MQTT device)",
            "unit": "unit:PERCENT",
            "minimum": 0,
            "maximum": 100,
            "readOnly": true,
            "observable": true,
            "forms": [
                {
                    "href": "http://localhost:8080/temphumiditysensor/properties/humidityPct",
                    "contentType": "application/json",
                    "op": ["readproperty", "observeproperty"]
                }
            ]
        },
        "status": {
            "type": "string",
            "title": "Status",
            "description": "Connection status of the device (cached)",
            "enum": ["online", "offline", "error"],
            "readOnly": true,
            "observable": true,
            "forms": [
                {
                    "href": "http://localhost:8080/temphumiditysensor/properties/status",
                    "contentType": "application/json",
                    "op": ["readproperty", "observeproperty"]
                }
            ]
        }
    }
}
